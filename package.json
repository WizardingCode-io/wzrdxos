  "description": "WZRDX — open-source operating system for AI agent teams. Native-first orchestration over Claude Code primitives.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
