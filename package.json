    "wzrdx": "pnpm --filter @wzrdx/core exec wzrdx"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
